DB_USERNAME=postgres
DB_PASSWORD=change-me
DB_JDBC_URL=jdbc:postgresql://localhost:5433/api

# Use URI format for key locations.
# Windows example: file:///C:/secure-path/privateKey.pem
# Linux/macOS example: file:///home/user/.secrets/api/privateKey.pem
JWT_PRIVATE_KEY_LOCATION=file:///C:/secure-path/privateKey.pem
JWT_PUBLIC_KEY_LOCATION=file:///C:/secure-path/publicKey.pem
JWT_ISSUER=udesc-api

# Set true only for isolated test databases
TEST_DB_CLEAN_AT_START=false
